{
	"name": "chat-udp",
	"description": "Chat UDP Multicast com interface Swing",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"build": "javac -d dist -sourcepath src;../../packages/logging/java/src src/*.java",
		"dev": "java -cp dist Main",
		"test": "javac -d dist/test -sourcepath src;test src/JsonHelper.java test/*.java && java -cp dist/test JsonHelperTest",
		"lint": "javac -Xlint -d dist -sourcepath src;../../packages/logging/java/src src/*.java",
		"typecheck": "javac -Xlint -d dist -sourcepath src;../../packages/logging/java/src src/*.java",
		"format": "node ../../tools/java/checkstyle-runner.cjs src/*.java",
		"clean": "if exist dist rmdir /s /q dist"
	}
}
