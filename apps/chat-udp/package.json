{
	"name": "chat-udp",
	"description": "Chat UDP Multicast com interface Swing",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"build": "javac -d dist src/*.java",
		"dev": "java -cp dist Main",
		"test": "echo 'Testes: pendentes'",
		"lint": "javac -Xlint -d dist src/*.java",
		"typecheck": "javac -Xlint -d dist src/*.java",
		"format": "node ../../tools/java/checkstyle-runner.cjs src/*.java",
		"clean": "if exist dist rmdir /s /q dist"
	}
}
