{
  "name": "udp-iot",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "applications/*",
    "packages/*"
  ],
  "packageManager": "npm@10.9.2",
  "scripts": {
    "biome:fix": "biome check --write",
    "build": "turbo run build",
    "dev": "turbo run dev --ui=tui",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "clean": "echo 'Run clean inside udp-iot workspace'",
    "postinstall": "bash scripts/init-config.sh"
  }
}
