# ===========================================
# Portas dos servidores (GUI TypeScript/Node.js)
# ===========================================

# Matriz GUI - servidor HTTP + WebSocket
MATRIZ_PORT=3001

# Filial GUI - servidor HTTP + WebSocket
FILIAL_GUI_PORT=8082

# Filial GUI - porta do servidor UDP (comunica com Matriz)
FILIAL_UDP_PORT=51000

# ===========================================
# Portas Vite dev servers (frontends React)
# ===========================================

VITE_MATRIZ_PORT=5173
VITE_FILIAL_PORT=5174

# ===========================================
# URLs completas (opcional - construídas das portas acima)
# ===========================================
VITE_MATRIZ_API_URL=http://localhost:3001
VITE_MATRIZ_WS_URL=ws://localhost:3001/ws
VITE_FILIAL_API_URL=http://localhost:8082
VITE_FILIAL_WS_URL=ws://localhost:8082/ws

# ===========================================
# Java apps (lidos via shared/Env.java)
# ===========================================

# Matriz Java - HTTP + WebSocket
MATRIZ_HTTP_PORT=8080

# ===========================================
# Portas padrão para filiais (comunicação UDP Matriz → Filial)
# ===========================================

# Porta padrão para filial 1
FILIAL1_PORT=51000
MATRIZ_CONFIG_PATH=packages/config/config_matriz.json
FILIAL_CONFIG_PATH=packages/config/config_filial.json
