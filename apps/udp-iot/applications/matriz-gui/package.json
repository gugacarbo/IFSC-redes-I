{
  "name": "@udp-iot/matriz-gui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:all",
    "dev:client": "vite",
    "dev:server": "tsx server/index.ts",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "lint": "tsc -b",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true});require('node:fs').rmSync('.turbo',{recursive:true,force:true});\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "@udp-iot/ui": "*",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^11.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.6",
    "tsx": "^4.19.0",
    "typescript": "~5.7.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.6"
  }
}
