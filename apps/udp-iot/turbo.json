{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": [
				"^build"
			],
			"outputs": [
				"build/**",
				"dist/**",
				".out/**",
				"*.class"
			]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": [
				"^build"
			]
		},
		"test": {
			"dependsOn": [
				"^build"
			]
		},
		"typecheck": {
			"dependsOn": [
				"^build"
			]
		},
		"format": {
			"cache": false
		},
		"extends": {}
	}
}
