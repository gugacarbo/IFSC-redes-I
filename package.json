{
	"name": "ifsc-estrutura-de-dados",
	"private": true,
	"license": "MIT",
	"type": "module",
	"packageManager": "^npm@10.9.2",
	"workspaces": [
		"launcher",
		"apps/*"
	],
	"author": {
		"name": "Gustavo Carbonera",
		"url": "https://github.com/gugacarbo"
	},
	"scripts": {
		"start": "npm run start --workspace=launcher",
		"test": "turbo run test",
		"lint": "turbo run lint",
		"build": "turbo run build",
		"typecheck": "turbo run typecheck",
		"format:packages": "turbo run format",
		"format": "biome check --write",
		"format:md": "prettier --write \"**/*.md\"",
		"format:java": "node ./tools/java/checkstyle-runner.cjs",
		"lint-staged": "lint-staged",
		"download-checkstyle": "powershell -ExecutionPolicy Bypass -File tools/java/download-checkstyle.ps1",
		"prepare": "husky; npm run download-checkstyle",
		"postinstall": "npm run download-checkstyle",
		"knip": "knip"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@types/node": "^25.6.0",
		"husky": "^9.1.7",
		"knip": "^6.11.0",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.3",
		"test-staged": "^1.1.11",
		"turbo": "^2.9.9",
		"typescript": "^6.0.3"
	}
}
